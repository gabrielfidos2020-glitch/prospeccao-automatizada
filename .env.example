# Variáveis de ambiente — copie para .env e preencha os valores reais
# O arquivo .env NÃO deve ser commitado (já está no .gitignore)

# ─── SerpAPI (captação de leads via Google Maps) ──────────
SERP_API_KEY=

# ─── WhatsApp (Evolution API) ─────────────────────────────
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ─── Instagram (Instagrapi) ───────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ─── n8n ──────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=admin
